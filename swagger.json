                                }
                            }
                        }
                    }
                }
            }
        },
        "/serie/edit": {
            "put": {
                "description": "editar uma serie existente",
                "security": [{ "bearerAuth": [] }],
                "parameters": [
                    {
                        "name": "serie_id",
                        "in": "query",
                        "description": "id da serie a ser editada",
                        "required": true,
                        "schema": { "type": "string", "format": "uuid" }
                    }
                ],
                "requestBody": {
                    "description": "dados necessarios para a edicao da serie",
                    "content": {
                        "multipart/form-data": {
                            "schema": {
                                "$ref": "#/components/schemas/RequestEditSerie"
