                },
                "responses": {
                    "200": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ResponseCreateGenero"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/genero/edit": {
            "put": {
                "description": "editar um genero existente",
                "security": [{ "bearerAuth": [] }],
                "parameters": [
                    {
                        "name": "genero_id",
                        "in": "query",
                        "description": "id do genero a ser editado",
                        "required": true,
                        "schema": { "type": "string", "format": "uuid" }
                    }
                ],
                "requestBody": {
                    "description": "dados necessarios para a edicao do genero",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/RequestEditGenero"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ResponseCreateGenero"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/genero/all": {
            "get": {
                "description": "listar todos os generos",
                "security": [{ "bearerAuth": [] }],
                "responses": {
                    "200": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ResponseGetAllGeneros"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/genero/remove": {
            "delete": {
                "description": "remover um genero pelo seu id",
                "security": [{ "bearerAuth": [] }],
                "parameters": [
                    {
                        "name": "genero_id",
                        "in": "query",
                        "description": "id do genero a ser removido",
                        "required": true,
                        "schema": { "type": "string", "format": "uuid" }
                    }
                ],
                "responses": {
                    "200": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ResponseDeleteGenero"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/serie": {
            "post": {
                "description": "criar uma nova serie",
                "security": [{ "bearerAuth": [] }],
                "requestBody": {
                    "description": "dados necessarios para a criacao de uma nova serie",
                    "content": {
                        "multipart/form-data": {
                            "schema": {
                                "$ref": "#/components/schemas/RequestCreateSerie"
