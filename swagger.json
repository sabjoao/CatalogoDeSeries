{
    "openapi": "3.0.0",
    "info": {
        "title": "API Catálogo de Séries",
        "description": "esta api tem como objetivo facilitar o gerenciamento de um catálogo de séries",
        "contact": {
            "email": "sabino.jp03@gmail.com"
        },
        "version": "1.0.0"
    },
    "paths": {
        "/user": {
            "post": {
                "description": "criar um novo usuario",
                "requestBody": {
                    "description": "dados necessarios para a criacao de um novo usuario",
                    "content": {
                        "multipart/form-data": {
                            "schema": {
                                "$ref": "#/components/schemas/RequestCreateUser"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ResponseCreateUser"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/session": {
            "post": {
                "description": "logar e autenticar o usuario",
                "requestBody": {
                    "description": "dados necessarios para o login e autenticacao do usuario",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/RequestAuthUser"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ResponseAuthUser"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/me": {
            "get": {
                "description": "buscar dados do usuario autenticado",
                "security": [{ "bearerAuth": [] }],
                "responses": {
                    "200": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ResponseCreateUser"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/user/edit": {
            "put": {
                "description": "editar dados do usuario autenticado",
                "security": [{ "bearerAuth": [] }],
                "requestBody": {
                    "description": "dados necessarios para a edicao do usuario",
                    "content": {
                        "multipart/form-data": {
                            "schema": {
                                "$ref": "#/components/schemas/RequestEditUser"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ResponseCreateUser"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/user/remove": {
            "delete": {
                "description": "remover o usuario autenticado",
                "security": [{ "bearerAuth": [] }],
                "parameters": [
                    {
                        "name": "user_id",
                        "in": "query",
                        "description": "id do usuario a ser removido",
                        "required": true,
                        "schema": { "type": "string", "format": "uuid" }
                    }
                ],
                "responses": {
                    "200": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ResponseDeleteUser"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/genero": {
            "post": {
                "description": "criar um novo genero",
                "security": [{ "bearerAuth": [] }],
                "requestBody": {
                    "description": "dados necessarios para a criacao de um novo genero",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/RequestCreateGenero"
                            }
