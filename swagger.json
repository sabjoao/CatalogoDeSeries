                    "senha": { "type": "string" },
                    "file": { "type": "string", "format": "binary" }
                }
            },
            "ResponseCreateUser": {
                "type": "object",
                "properties": {
                    "id": { "type": "string" },
                    "nome": { "type": "string" },
                    "email": { "type": "string" },
                    "imagem": { "type": "string" }
                }
            },
            "RequestAuthUser": {
                "type": "object",
                "properties": {
                    "email": { "type": "string" },
