                    "nome": { "type": "string" },
                    "descricao": { "type": "string" }
                }
            },
            "ResponseGetAllGeneros": {
                "type": "array",
                "items": {
                    "type": "object",
                    "properties": {
                        "id": { "type": "string" },
                        "nome": { "type": "string" },
                        "descricao": { "type": "string" }
                    }
                }
            },
            "ResponseDeleteGenero": {
                "type": "object",
                "properties": {
